# Attributes for Git
# Ensures consistent line endings and proper handling of files

# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf
*.pyw text eol=lf
*.pyx text eol=lf
*.pxd text eol=lf

# Jupyter notebooks
*.ipynb text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# PowerShell scripts
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf

# Docker files
Dockerfile* text eol=lf
*.dockerfile text eol=lf
docker-compose*.yml text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# JSON files
*.json text eol=lf

# Markdown files
*.md text eol=lf
*.markdown text eol=lf

# SQL files
*.sql text eol=lf

# Configuration files
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.config text eol=lf
.editorconfig text eol=lf

# Requirements files
requirements*.txt text eol=lf

# Git files
.gitattributes text eol=lf
.gitignore text eol=lf
.gitkeep text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.parquet binary
*.pyc binary
*.pyd binary
*.pyo binary
*.so binary
*.dll binary
*.exe binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary

# Archives
*.jar binary
*.war binary
*.ear binary

# Excel files
*.xls binary
*.xlsx binary
*.xlsm binary

# VS Code workspace
*.code-workspace text eol=lf

# Linguist - exclude from language statistics
data/** linguist-vendored
notebooks/**.ipynb linguist-documentation
docs/** linguist-documentation
